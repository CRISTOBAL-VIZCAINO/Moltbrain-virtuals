    "base",
    "ai-agents",
    "memory",
    "eip-3009",
    "usdc",
    "micropayments"
  ],
  "author": "nhevers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nhevers/Moltbrain-virtuals"
  },
  "dependencies": {
    "@virtuals-protocol/game": "^0.1.9",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist"
  ]
}
